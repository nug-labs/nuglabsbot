        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_NUGLABS_PGQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH activity AS (SELECT from_id::bigint AS uid, at AS ts FROM analytics_events WHERE from_id IS NOT NULL AND event_name IN ('bot_text_query','bot_paste_link','bot_strain_found','bot_strain_not_found') UNION ALL SELECT user_id AS uid, event_at AS ts FROM app_analytics WHERE user_id IS NOT NULL AND event_name IN ('unknown-response','url-processed','strain-found','strain-not-found')), scoped AS (SELECT uid, $__timeGroup(ts, $__interval) AS bucket FROM activity WHERE $__timeFilter(ts)), totals AS (SELECT bucket AS time, COUNT(DISTINCT uid)::double precision AS total_users FROM scoped GROUP BY 1), first_seen AS (SELECT uid, MIN(ts) AS first_seen FROM activity GROUP BY uid), news AS (SELECT $__timeGroup(first_seen, $__interval) AS time, COUNT(*)::double precision AS new_users FROM first_seen WHERE $__timeFilter(first_seen) GROUP BY 1), series AS (SELECT t.time, 'total_users'::text AS metric, t.total_users AS value FROM totals t UNION ALL SELECT t.time, 'new_users'::text AS metric, COALESCE(n.new_users, 0)::double precision AS value FROM totals t LEFT JOIN news n ON n.time = t.time UNION ALL SELECT t.time, 'returning_users'::text AS metric, GREATEST(t.total_users - COALESCE(n.new_users, 0), 0)::double precision AS value FROM totals t LEFT JOIN news n ON n.time = t.time) SELECT * FROM series ORDER BY time;",
          "refId": "A"
        }
      ],
      "title": "New users vs returning users (over time)",
      "type": "timeseries"
    },
