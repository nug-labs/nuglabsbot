            "uid": "${DS_NUGLABS_PGQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH misses AS (SELECT COALESCE(query, strain_name, 'unknown') AS query, at AS ts, from_id::bigint AS uid, COALESCE(username, 'id:' || from_id::text) AS uname FROM analytics_events WHERE $__timeFilter(at) AND event_name = 'bot_strain_not_found' UNION ALL SELECT COALESCE(meta-\u003e\u003e'query', meta-\u003e\u003e'name', meta-\u003e\u003e'key', 'unknown') AS query, event_at AS ts, user_id AS uid, COALESCE(u.username, 'id:' || a.user_id::text) AS uname FROM app_analytics a LEFT JOIN users u ON u.telegram_id = a.user_id WHERE $__timeFilter(a.event_at) AND a.event_name = 'strain-not-found') SELECT query, COUNT(*) AS attempts, MAX(ts) AS last_seen, STRING_AGG(uname, ', ' ORDER BY ts DESC, uname ASC) AS users FROM misses GROUP BY query ORDER BY last_seen DESC, attempts DESC, query ASC LIMIT 50;",
          "refId": "A"
        }
      ],
      "title": "Failed strain search DLQ",
      "type": "table"
