          "rawSql": "WITH x AS (SELECT event_name FROM analytics_events WHERE $__timeFilter(at) AND event_name IN ('bot_strain_found','bot_strain_not_found') UNION ALL SELECT CASE WHEN event_name='strain-found' THEN 'bot_strain_found' WHEN event_name='strain-not-found' THEN 'bot_strain_not_found' ELSE event_name END FROM app_analytics WHERE $__timeFilter(event_at) AND event_name IN ('strain-found','strain-not-found')) SELECT COUNT(*) FILTER (WHERE event_name = 'bot_strain_found') * 100.0 / NULLIF(COUNT(*), 0) AS success_rate FROM x;",
