# APP_ENV: unset or test → .env.test first, then .env if DATABASE_URL still empty.
#           live/production/etc. → .env only. (docker live deploy sets APP_ENV=live via env file.)
# zz-ops: utils.Env.InitOps() defaults APP_ENV=test when unset so .env.test is used for DB tools.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_USERNAME=YourBotUsernameWithoutAt
# Long polling: timeout seconds for getUpdates (1–50; Telegram API max 50).
# GET_UPDATES_TIMEOUT_SECONDS=50
# Local: DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pokedex_telegram_v2?sslmode=disable
# Supabase pooler: user is postgres.PROJECT_REF (not plain postgres). Percent-encode password (space %20, ! %21).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:your_password@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
STRAIN_API_BASE_URL=https://strains.nuglabs.co
GEMINI_API_KEY=
ENABLE_ANALYTICS=true
LOG_LEVEL=info
POLL_BROADCAST_INTERVAL_SECONDS=60
